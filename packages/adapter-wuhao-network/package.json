{
  "name": "wuhao-vibe-network-adapter-wuhao-network",
  "version": "0.1.0",
  "description": "wuhao-network adapter for wuhao-vibe-network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "wuhao-vibe-network-core": "workspace:*"
  },
  "peerDependencies": {
    "wuhao-network": ">=1.0.0",
    "axios": "^1.3.5"
  },
  "peerDependenciesMeta": {
    "wuhao-network": { "optional": true },
    "axios": { "optional": true }
  },
  "engines": { "node": ">=18" },
  "license": "MIT"
}
