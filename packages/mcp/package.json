{
  "name": "wuhao-vibe-network-mcp",
  "version": "0.1.0",
  "description": "MCP Server + CLI for wuhao-vibe-network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wuhao-vibe-network": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/chmod-cli.mjs dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "wuhao-vibe-network-core": "workspace:*",
    "wuhao-vibe-network-orchestrator": "workspace:*",
    "wuhao-vibe-network-adapter-http": "workspace:*",
    "wuhao-vibe-network-adapter-wuhao-network": "workspace:*"
  },
  "engines": { "node": ">=18" },
  "license": "MIT"
}
