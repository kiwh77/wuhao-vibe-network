{
  "name": "wuhao-vibe-network-example-standalone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "mcp:serve": "wuhao-vibe-network serve --entry ./mcp/index.mjs",
    "mcp:tools": "wuhao-vibe-network tools list --entry ./mcp/index.mjs --json",
    "mcp:materials": "wuhao-vibe-network materials list --entry ./mcp/index.mjs --json",
    "mcp:call": "wuhao-vibe-network tools call demo_echo_get --entry ./mcp/index.mjs --data '{\"message\":\"ok\"}' --json"
  },
  "dependencies": {
    "wuhao-vibe-network-mcp": "workspace:*"
  }
}
